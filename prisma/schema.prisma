generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Organization {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  ownerId   String
  logoUrl   String?
  brandColor String?
  customDomain String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  owner   User                @relation("OrgOwner", fields: [ownerId], references: [id])
  members OrganizationMember[]
  documents Document[]
  permissions Permission[]
  formTemplates FormTemplate[]
  assignments Assignment[]
  workflows SignatureWorkflow[]
  publicTemplates PublicTemplate[]
  webhooks  Webhook[]
  emailTemplates EmailTemplate[]
  apiKeys   ApiKey[]
  folders   Folder[]
  usageStats UsageStat[]
  permissionTemplates PermissionTemplate[]
}

model OrganizationMember {
  id            String    @id @default(cuid())
  role          String    @default("member") // owner, admin, editor, signer, viewer, member
  inviteStatus  String    @default("active") // pending, active, rejected
  invitedBy     String?
  isActive      Boolean   @default(true)
  lastLoginAt   DateTime?
  createdAt     DateTime  @default(now())
  joinedAt      DateTime  @default(now())
  userId        String
  orgId         String

  user   User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  inviter User?       @relation("InvitedBy", fields: [invitedBy], references: [id])

  @@unique([userId, orgId])
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  company   String?
  jobTitle  String?
  phone     String?
  avatarUrl String?
  telegramChatId String?   @unique // linked Telegram chat id
  telegramLinkedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  documents        Document[]
  auditLogs        AuditLog[]
  templates        DocumentTemplate[]
  formTemplates    FormTemplate[]
  savedSignatures  SavedSignature[]
  ownedOrgs        Organization[]       @relation("OrgOwner")
  organizationMembers OrganizationMember[]
  invitedMembers   OrganizationMember[] @relation("InvitedBy")
  permissions      Permission[]
  grantedPermissions Permission[] @relation("GrantedPermissions")
  assignments      Assignment[]
  assignedDocs     Assignment[]       @relation("AssignedBy")
  notifications    Notification[]
  reminders        Reminder[]
  createdWorkflows SignatureWorkflow[]
  workflowSteps    WorkflowStep[]
  apiKeys          ApiKey[]
  contacts         Contact[]
  groups           ContactGroup[]
  publicTemplates  PublicTemplate[]
  webhooks         Webhook[]
  folders          Folder[]
  usageStats       UsageStat[]
  preferences      UserPreferences?
  comments         DocumentComment[]
  telegramBindings TelegramBinding[]
}

model UserPreferences {
  id               String   @id @default(cuid())
  userId           String   @unique
  avatarUrl        String?
  emailOnSent      Boolean  @default(true)
  emailOnCompleted Boolean  @default(true)
  emailOnRejected  Boolean  @default(true)
  emailOnExpiring  Boolean  @default(true)
  emailOnReminder  Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Document {
  id              String    @id @default(cuid())
  title           String
  originalPdfPath String
  signedPdfPath   String?
  certificatePath String?
  status          String    @default("Draft") // Draft, Sent, Signing, Completed, Rejected, Expired, Revoked
  ownerId         String
  expiresAt       DateTime?
  signedSelf      Boolean   @default(false)
  filePassword    String?
  revokedAt       DateTime?
  revokedBy       String?
  revokeReason    String?
  allowOfflineSign Boolean  @default(true)
  requireOtp      Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime  @updatedAt
  organizationId  String?
  folderId        String?

  owner         User           @relation(fields: [ownerId], references: [id])
  organization  Organization?  @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  signers       Signer[]
  fields        DocumentField[]
  ccRecipients  CcRecipient[]
  auditLogs     AuditLog[]
  templateId    String?
  template      DocumentTemplate? @relation(fields: [templateId], references: [id])
  templateUsages TemplateUsage[]
  assignments   Assignment[]
  workflowId    String?
  workflow      SignatureWorkflow? @relation(fields: [workflowId], references: [id])
  notifications Notification[]
  reminders     Reminder[]
  docReminders  DocumentReminder[]
  downloadLinks DownloadLink[]
  permissions   Permission[]
  versions      DocumentVersion[]
  tags          DocumentTag[]
  comments      DocumentComment[]
  shareLinks    ShareLink[]
}

model ShareLink {
  id         String   @id @default(cuid())
  documentId String
  token      String   @unique
  expiresAt  DateTime?
  viewOnly   Boolean  @default(true)
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([token])
}

model DocumentComment {
  id         String   @id @default(cuid())
  documentId String
  userId     String
  content    String
  pageNumber Int?
  x          Float?
  y          Float?
  resolved   Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([documentId])
}

model DocumentTag {
  id         String   @id @default(cuid())
  documentId String
  name       String
  color      String?  @default("#10b981")
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, name])
  @@index([documentId])
}

model DocumentVersion {
  id              String   @id @default(cuid())
  documentId      String
  version         Int
  pdfPath         String
  title           String
  changedBy       String?
  changeNote      String?
  createdAt       DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId, version])
}

model DocumentTemplate {
  id         String   @id @default(cuid())
  name       String
  ownerId    String
  fieldConfig String // JSON: array of field definitions
  roles       String  @default("[]") // JSON: array of role definitions
  allowOfflineSign Boolean @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  owner     User              @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  documents Document[]
  usage     TemplateUsage[]
}

model TemplateUsage {
  id         String   @id @default(cuid())
  templateId String
  documentId String
  usedAt     DateTime @default(now())

  template DocumentTemplate @relation(fields: [templateId], references: [id], onDelete: Cascade)
  document Document         @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([templateId])
}

model Signer {
  id              String    @id @default(cuid())
  email           String
  name            String
  phone           String?
  order           Int       @default(1)
  role            String    @default("signer") // signer, approver, viewer
  signedAt        DateTime?
  rejectedAt      DateTime?
  rejectionReason String?
  token           String    @unique
  otpCode         String?
  otpMethod       String    @default("email") // email or sms
  otpVerifiedAt   DateTime?
  otpRequestedAt  DateTime?
  documentId      String
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  document Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  fields   DocumentField[]
}

model DocumentField {
  id         String   @id @default(cuid())
  type       String   // signature, date, text, initials, checkbox, dropdown
  label      String?
  required   Boolean  @default(true)
  options    String?  // JSON array of options for dropdown/checkbox fields, e.g. '["Yes","No"]'
  pageNumber Int
  x          Float
  y          Float
  width      Float
  height     Float
  value      String?
  signerId   String?
  documentId String
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  signer   Signer?  @relation(fields: [signerId], references: [id], onDelete: SetNull)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model CcRecipient {
  id         String   @id @default(cuid())
  email      String
  name       String
  documentId String
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model SavedSignature {
  id        String   @id @default(cuid())
  name      String
  dataUrl   String   // base64 image data
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String   @id @default(cuid())
  action     String
  ipAddress  String?
  userAgent  String?
  details    String?
  documentId String?
  userId     String?
  signerId   String?
  createdAt  DateTime @default(now())

  document Document? @relation(fields: [documentId], references: [id], onDelete: SetNull)
  user     User?     @relation(fields: [userId], references: [id], onDelete: SetNull)
}

model Permission {
  id         String    @id @default(cuid())
  resource   String    // e.g., "document", "template", "report"
  action     String    // e.g., "create", "read", "update", "delete"
  granted    Boolean   @default(true)
  userId     String
  orgId      String?
  documentId String?
  templateId String?
  grantedBy  String?
  expiresAt  DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  user     User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  org      Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
  document Document?     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  template FormTemplate? @relation(fields: [templateId], references: [id], onDelete: Cascade)
  grantor  User?         @relation("GrantedPermissions", fields: [grantedBy], references: [id], onDelete: SetNull)

  @@unique([userId, orgId, resource, action])
  @@unique([userId, documentId, action])
  @@unique([userId, templateId, action])
}

model PermissionTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  orgId       String
  permissions String   // JSON array of permission objects
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model FormTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  schema      String   // JSON: form field definitions
  shareToken  String?  @unique
  orgId       String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org         Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator     User            @relation(fields: [createdBy], references: [id])
  fields      FormField[]
  permissions Permission[]
  submissions FormSubmission[]
}

model FormSubmission {
  id              String   @id @default(cuid())
  data            String   // JSON: submitted form data
  formTemplateId  String
  submittedAt     DateTime @default(now())

  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
}

model FormField {
  id            String   @id @default(cuid())
  type          String   // text, number, date, select, checkbox, signature
  label         String
  placeholder   String?
  required      Boolean  @default(false)
  options       String?  // JSON array for select fields
  defaultValue  String?
  validation    String?  // JSON validation rules
  formTemplateId String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  formTemplate FormTemplate @relation(fields: [formTemplateId], references: [id], onDelete: Cascade)
}

model SignatureWorkflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  orgId       String
  createdBy   String
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User        @relation(fields: [createdBy], references: [id])
  steps   WorkflowStep[]
  documents Document[]

  @@unique([orgId, name])
}

model WorkflowStep {
  id          String   @id @default(cuid())
  name        String
  order       Int
  stepType    String   @default("sign") // sign, approve, review, cc
  userId      String
  workflowId  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workflow SignatureWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  user     User              @relation(fields: [userId], references: [id])

  @@unique([workflowId, order])
  @@unique([workflowId, userId])
}

model Assignment {
  id          String   @id @default(cuid())
  status      String   @default("pending") // pending, in_progress, completed, overdue
  dueDate     DateTime?
  completedAt DateTime?
  notes       String?
  userId      String
  documentId  String
  orgId       String
  assignedBy  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user      User         @relation(fields: [userId], references: [id])
  document  Document     @relation(fields: [documentId], references: [id], onDelete: Cascade)
  org       Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  assigner  User         @relation("AssignedBy", fields: [assignedBy], references: [id])

  @@unique([userId, documentId])
}

model Notification {
  id         String   @id @default(cuid())
  type       String   // assignment, reminder, status_change, mention
  title      String
  message    String
  read       Boolean  @default(false)
  userId     String
  documentId String?
  createdAt  DateTime @default(now())

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document? @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model TelegramBinding {
  id          String   @id @default(cuid())
  token       String   @unique // one-time linking token shown to the user
  chatId      String                 // Telegram chat id captured at /start
  username    String?
  firstName   String?
  linkedUserId String?              // set once the token is redeemed
  consumedAt  DateTime?
  createdAt   DateTime @default(now())

  user User? @relation(fields: [linkedUserId], references: [id], onDelete: SetNull)
}

model Reminder {
  id         String   @id @default(cuid())
  type       String   // signing_due, follow_up, overdue
  scheduledAt DateTime
  sentAt     DateTime?
  message    String
  userId     String
  documentId String
  createdAt  DateTime @default(now())

  user     User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}

model DocumentReminder {
  id         String   @id @default(cuid())
  documentId String
  email      String
  name       String?
  intervalDays Int    @default(3)
  lastSentAt  DateTime?
  nextSendAt  DateTime
  enabled    Boolean  @default(true)
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@index([documentId])
  @@index([nextSendAt])
}

model PublicTemplate {
  id          String   @id @default(cuid())
  name        String
  description String?
  shareToken  String   @unique
  isActive    Boolean  @default(true)
  fieldConfig String   // JSON: field definitions
  orgId       String
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User        @relation(fields: [createdBy], references: [id])
}

model Webhook {
  id        String   @id @default(cuid())
  url       String
  secret    String
  events    String   // JSON array of event types
  isActive  Boolean  @default(true)
  orgId     String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org    Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator User        @relation(fields: [createdBy], references: [id])
  events_log WebhookEvent[]
}

model WebhookEvent {
  id         String   @id @default(cuid())
  webhookId  String
  event      String   // document.created, document.completed, signer.signed, etc.
  payload    String   // JSON payload
  status     String   @default("pending") // pending, sent, failed
  attempts   Int      @default(0)
  lastError  String?
  createdAt  DateTime @default(now())
  sentAt     DateTime?

  webhook Webhook @relation(fields: [webhookId], references: [id], onDelete: Cascade)
}

model EmailTemplate {
  id        String   @id @default(cuid())
  name      String
  subject   String
  htmlBody  String
  orgId     String?
  isDefault Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  org Organization? @relation(fields: [orgId], references: [id], onDelete: Cascade)
}

model ApiKey {
  id        String   @id @default(cuid())
  name      String
  key       String   @unique
  permissions String  // JSON array of permissions
  userId    String
  orgId     String
  lastUsedAt DateTime?
  expiresAt DateTime?
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([userId, name])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  company   String?
  userId    String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user   User                   @relation(fields: [userId], references: [id], onDelete: Cascade)
  groups ContactGroupMember[]

  @@unique([userId, email])
}

model ContactGroup {
  id        String   @id @default(cuid())
  name      String
  userId    String
  createdAt DateTime @default(now())

  user     User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  contacts ContactGroupMember[]

  @@unique([userId, name])
  @@index([userId])
}

model ContactGroupMember {
  id        String @id @default(cuid())
  groupId   String
  contactId String

  group   ContactGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  contact Contact      @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([groupId, contactId])
}

model Folder {
  id        String   @id @default(cuid())
  name      String
  parentId  String?
  orgId     String
  createdBy String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  parent   Folder?      @relation("FolderTree", fields: [parentId], references: [id], onDelete: SetNull)
  children Folder[]     @relation("FolderTree")
  org      Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator  User         @relation(fields: [createdBy], references: [id])
}

model UsageStat {
  id        String   @id @default(cuid())
  userId    String
  orgId     String?
  metric    String   // documents_created, documents_signed, emails_sent, api_calls
  value     Int      @default(1)
  period    String   // 2026-07 (YYYY-MM)
  createdAt DateTime @default(now())

  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  org  Organization? @relation(fields: [orgId], references: [id], onDelete: SetNull)

  @@unique([userId, orgId, metric, period])
}

model DownloadLink {
  id         String   @id @default(cuid())
  token      String   @unique
  documentId String
  type       String   // signed_pdf, certificate
  expiresAt  DateTime
  createdAt  DateTime @default(now())

  document Document @relation(fields: [documentId], references: [id], onDelete: Cascade)
}